# ── A4 Environment Secrets ─────────────────────────────────────────────────────
# Copy this file to .env and fill in values for your environment.
# .env is gitignored and will not be committed.

API_TOKEN=changeme

# Postgres
DB_USER=iot_user
DB_PASSWORD=changeme

# RabbitMQ
RABBITMQ_USER=iot_service
RABBITMQ_PASS=changeme

# Scaling
SENSOR_REPLICAS=1
ALERT_REPLICAS=1
PIPELINE_MODE=blocking
WORKER_COUNT=4
